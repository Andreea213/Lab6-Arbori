#include <stdbool.h>
#include <limits.h> // Pentru LONG_MIN și LONG_MAX

// Funcția "All-in-One" care primește nodul și intervalul permis
bool esteBST(struct node* nod, long min, long max) {
    // 1. Condiția de oprire: un arbore gol este BST
    if (nod == NULL) {
        return true;
    }

    // 2. Verificăm dacă valoarea nodului curent respectă intervalul
    // Dacă valoarea nodului "sare" din gard, oprim totul
    if (nod->data <= min || nod->data >= max) {
        return false;
    }

    // 3. RECURSIVITATEA:
    // Pentru STÂNGA: valoarea maximă permisă devine nod->data
    // Pentru DREAPTA: valoarea minimă permisă devine nod->data
    return esteBST(nod->leftChild, min, nod->data) && 
           esteBST(nod->rightChild, nod->data, max);
}

